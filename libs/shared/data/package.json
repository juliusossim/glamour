{
  "name": "@org/shared-data",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "nx": {
    "targets": {
      "typecheck": {
        "command": "tsc -b libs/shared/data/tsconfig.lib.json --emitDeclarationOnly"
      }
    },
    "tags": [
      "scope:shared",
      "type:data-access"
    ]
  },
  "devDependencies": {
    "@org/models": "workspace:*"
  }
}
