{
  "name": "@org/shared-hooks",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@org/source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "nx": {
    "targets": {
      "typecheck": {
        "command": "tsc -b libs/shared/hooks/tsconfig.lib.json --emitDeclarationOnly"
      },
      "test": {
        "command": "vitest --config libs/shared/hooks/vitest.config.mts --passWithNoTests=true"
      }
    },
    "tags": [
      "scope:shared",
      "type:shared"
    ]
  }
}
